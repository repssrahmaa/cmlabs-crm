generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  EXECUTIVE
  SALES_MANAGER
  ACCOUNT_EXECUTIVE
  VIEWER
}

enum LeadStatus {
  LEAD_IN
  CONTACT_MADE
  NEEDS_IDENTIFIED
  PROPOSAL_MADE
  NEGOTIATION
  CONTRACT_SENT
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  NOTE
  CALL
  MEETING
  TASK
  INTERNAL_NOTE
  EMAIL_SENT
  EMAIL_RECEIVED
}

enum MailStatus {
  DRAFT
  SENT
  ARCHIVED
}

enum DocumentType {
  INVOICE
  SPK
  MOU
  OTHER
}

enum DocumentStatus {
  DRAFT
  FINALIZED
  SENT
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ACCOUNT_EXECUTIVE)
  avatar    String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedLeads Lead[]     @relation("AssignedTo")
  createdLeads  Lead[]     @relation("CreatedBy")
  activities    Activity[]
  sentMails     Mail[]     @relation("MailSender")
  receivedMails Mail[]     @relation("MailReceiver")

  @@map("users")
}

model Lead {
  id            String       @id @default(cuid())
  title         String
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientCompany String?
  status        LeadStatus   @default(LEAD_IN)
  priority      LeadPriority @default(MEDIUM)
  value         Decimal?     @db.Decimal(15, 2)
  description   String?
  source        String?
  closedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assignedToId String?
  createdById  String

  assignedTo User?      @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User       @relation("CreatedBy",  fields: [createdById],  references: [id])
  activities Activity[]
  mails      Mail[]
  documents  Document[]

  @@map("leads")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  content     String?
  description String?
  dueDate     DateTime?
  isDone      Boolean      @default(false)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  leadId String
  userId String

  lead  Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id])
  email Email?

  @@map("activities")
}

model Email {
  id          String      @id @default(cuid())
  activityId  String      @unique
  toAddress   String
  fromAddress String
  subject     String
  body        String
  htmlBody    String?
  status      EmailStatus @default(PENDING)
  sentAt      DateTime?
  errorLog    String?
  createdAt   DateTime    @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("emails")
}

model Mail {
  id         String     @id @default(cuid())
  subject    String
  body       String
  status     MailStatus @default(DRAFT)
  sentAt     DateTime?
  createdAt  DateTime   @default(now())

  senderId   String
  receiverId String
  leadId     String?

  sender   User  @relation("MailSender",   fields: [senderId],   references: [id])
  receiver User  @relation("MailReceiver", fields: [receiverId], references: [id])
  lead     Lead? @relation(fields: [leadId], references: [id])

  @@map("mails")
}

model Document {
  id        String         @id @default(cuid())
  type      DocumentType
  title     String
  content   Json
  status    DocumentStatus @default(DRAFT)
  fileUrl   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  leadId String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("documents")
}